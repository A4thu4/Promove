{
  "description": "Configuração dos Boards Kanban para os projetos técnicos do roadmap IMIGRATION_2030.",
  "organization": "ArthemizLabs",
  "type": "board",
  "workflow": {
    "columns": [
      {
        "name": "🗄️ Backlog",
        "description": "Ideias brutas e requisitos sem DoD definido. Issues recém-abertas entram aqui automaticamente.",
        "automation": {
          "triggers": ["issue_opened", "issue_reopened"]
        }
      },
      {
        "name": "✅ Ready to Dev",
        "description": "Issues com Definition of Done claro, critérios de aceite definidos e estimativa atribuída.",
        "automation": {
          "triggers": ["label_added:ready-to-dev"]
        }
      },
      {
        "name": "🔧 In Progress",
        "description": "Trabalho ativo. Máximo de 2 issues simultâneas por membro. Issue deve ter assignee.",
        "wip_limit": 2,
        "automation": {
          "triggers": ["issue_assigned", "label_added:in-progress"]
        }
      },
      {
        "name": "🔍 In Review",
        "description": "Código pronto aguardando Pull Request aberta ou revisão de pares.",
        "automation": {
          "triggers": ["pull_request_opened", "label_added:in-review"]
        }
      },
      {
        "name": "🚀 Done",
        "description": "Finalizado, testado, PR merged e deployed em ambiente de produção/staging.",
        "automation": {
          "triggers": ["pull_request_merged", "issue_closed"]
        }
      }
    ]
  },
  "projects": [
    {
      "id": "opsledger",
      "name": "OpsLedger — Backend & API",
      "repository": "ArthemizLabs/OpsLedger",
      "description": "Gestão de tarefas do backend Java (Spring Boot) do OpsLedger — APIs, serviços e integrações.",
      "stack": ["Java", "Spring Boot", "PostgreSQL", "REST API"],
      "phase": "PHASE_2026",
      "immigration_pillar": "Portfólio 💼",
      "labels": ["backend", "java", "api", "database", "bug", "enhancement", "ready-to-dev", "in-progress", "in-review"],
      "milestones": [
        { "title": "v0.1 — MVP",     "description": "CRUD básico e autenticação JWT" },
        { "title": "v0.2 — Reports", "description": "Módulo de relatórios e exportação" },
        { "title": "v1.0 — Stable",  "description": "Versão estável com testes e CI/CD" }
      ]
    },
    {
      "id": "sentinel-agent",
